# Banco (Neon Postgres). Use a connection string "pooler" (termina com -pooler.xxx.aws.neon.tech).
DATABASE_URL=postgresql://user:password@host/db?sslmode=require&channel_binding=require

# Chave HS256 usada pra assinar JWT da sessão (openssl rand -base64 32).
SESSION_SECRET=

# URL pública da app (pra montar links de reset de senha nos emails).
# Em dev: http://localhost:3000
# Em prod: https://seu-dominio.com
APP_URL=

# SMTP (Hostinger ou outro). Port 465 = TLS implícito.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Montana Zera Estoque <remetente@dominio.com>"
